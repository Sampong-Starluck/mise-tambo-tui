<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.1.0</version>
        <relativePath/> <!-- lookup parent from repository -->
    </parent>
    <groupId>com.sampong</groupId>
    <artifactId>mise-tambo</artifactId>
    <version>0.0.1</version>
    <name>mise-tambo</name>
    <description>A Spring CLI application for mise-en-place with TamboUI</description>

    <properties>
        <java.version>25</java.version>
        <tamboui.version>0.4.0</tamboui.version>
        <maven.test.skip>true</maven.test.skip>
    </properties>

    <repositories>
        <repository>
            <id>sonatype-snapshots</id>
            <url>https://central.sonatype.com/repository/maven-snapshots/</url>
            <snapshots><enabled>true</enabled></snapshots>
            <releases><enabled>false</enabled></releases>
        </repository>
    </repositories>

    <dependencies>
        <!-- Spring DI + auto-config, no web server -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
        </dependency>

        <!-- TamboUI: fluent Java DSL -->
        <dependency>
            <groupId>dev.tamboui</groupId>
            <artifactId>tamboui-toolkit</artifactId>
            <version>${tamboui.version}</version>
        </dependency>

        <!-- Panama (FFM) backend — auto-discovered via ServiceLoader -->
        <dependency>
            <groupId>dev.tamboui</groupId>
            <artifactId>tamboui-panama-backend</artifactId>
            <version>${tamboui.version}</version>
        </dependency>

        <!-- JSON parsing for `mise ... -J` output -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
        </dependency>

        <!-- Nullability annotations (@NullMarked / @Nullable): annotation-only,
             zero transitive deps, read by IDEs and static-analysis tooling. -->
        <dependency>
            <groupId>org.jspecify</groupId>
            <artifactId>jspecify</artifactId>
            <version>1.0.0</version>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                </configuration>
            </plugin>
            <!-- Maven's own default-test binding sets JUnit-Platform uid-tracking via the
                 deprecated systemProperties element; that config comes from the lifecycle's
                 default bindings, not POM inheritance, so overriding it here only merges
                 alongside the original instead of replacing it. maven.test.skip already
                 means this execution never runs anything, so disable it outright instead
                 of fighting the merge — this drops the warning along with it. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <executions>
                    <execution>
                        <id>default-test</id>
                        <phase>none</phase>
                    </execution>
                </executions>
            </plugin>
            <!-- GraalVM native image: build with `mvnw -Pnative native:compile` (the
                 parent's `native` profile binds process-aot and reachability metadata).
                 Requires GraalVM as JAVA_HOME and the MSVC C++ toolchain on Windows.
                 For a profile-guided-optimized build, see the pgo-instrument /
                 pgo-optimize profiles below. -->
            <plugin>
                <groupId>org.graalvm.buildtools</groupId>
                <artifactId>native-maven-plugin</artifactId>
                <configuration>
                    <buildArgs>
                        <!-- TamboUI's Panama backend uses the FFM API for terminal I/O -->
                        <buildArg>--enable-native-access=ALL-UNNAMED</buildArg>
                        <!-- WindowsTerminal allocates with Arena.ofShared(), which native
                             image only supports when this (experimental) flag is on -->
                        <buildArg>-H:+UnlockExperimentalVMOptions</buildArg>
                        <buildArg>-H:+SharedArenaSupport</buildArg>
                        <!-- Deliberately omitting the future-defaults flag GraalVM suggests:
                             tried it, and it makes native-image fatally error on this
                             project's fetched reachability-metadata ("Bulk queries can only
                             be set with 'name' which does not allow run-time conditions") —
                             some upstream metadata trips whatever conditional-reflection
                             default it flips on. Revisit on a future GraalVM/plugin bump. -->
                        <!-- Portable baseline CPU target: this binary gets built on one
                             machine and may run on another, so we deliberately do not use
                             -march=native (which ties the binary to the build machine's
                             exact CPU and can crash with an illegal-instruction error
                             elsewhere). -->
                        <buildArg>-march=compatibility</buildArg>
                        <!-- tambo's working set (tool/task/registry lists) is small; a fixed
                             cap gives predictable memory use instead of the GC growing the
                             heap on demand. Bump this if you manage a very large registry. -->
                        <buildArg>-R:MaxHeapSize=128m</buildArg>
                    </buildArgs>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- Profile-guided optimization, step 1: build an instrumented binary that
             records which code paths actually run. Usage:
               mvnw -Pnative,pgo-instrument native:compile
               target/mise-tambo   (use it through a normal session, then quit)
             This writes default.iprof into the project root. -->
        <profile>
            <id>pgo-instrument</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.graalvm.buildtools</groupId>
                        <artifactId>native-maven-plugin</artifactId>
                        <configuration>
                            <!-- combine.children="append": Maven's default plugin-config merge
                                 REPLACES the base buildArgs list rather than adding to it, which
                                 would silently drop the native-access/shared-arena flags this
                                 build needs just to succeed. -->
                            <buildArgs combine.children="append">
                                <buildArg>--pgo-instrument</buildArg>
                                <buildArg>-R:ProfilesDumpFile=${project.basedir}/default.iprof</buildArg>
                                <!-- Scope instrumentation to our own code: unrestricted
                                     instrumentation also injects counters into the FFM/Panama
                                     upcall stub TamboUI generates for terminal I/O, which
                                     crashes the Graal compiler backend (register-allocator
                                     assertion in the generated stub). -->
                                <buildArg>-H:ProfilingPackagePrefixes=com.sampong.tambo</buildArg>
                            </buildArgs>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- Profile-guided optimization, step 2: once default.iprof exists (from
             pgo-instrument above), rebuild the real binary with it applied:
               mvnw -Pnative,pgo-optimize native:compile
             Re-run pgo-instrument and this step again if the workload changes
             enough that the profile goes stale. -->
        <profile>
            <id>pgo-optimize</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.graalvm.buildtools</groupId>
                        <artifactId>native-maven-plugin</artifactId>
                        <configuration>
                            <buildArgs combine.children="append">
                                <buildArg>--pgo=${project.basedir}/default.iprof</buildArg>
                            </buildArgs>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

</project>